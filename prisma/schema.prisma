generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id
  name                String
  email               String
  emailVerified       Boolean              @default(false)
  image               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  sessions            Session[]
  accounts            Account[]
  role                String               @default("user")
  banned              Boolean?             @default(false)
  banReason           String?
  banExpires          DateTime?
  categories          Categories[]
  sectionContents     SectionContent[]
  heroInfos           HeroInfo[]
  aboutHomes          AboutHome[]
  features            Features[]
  workProcesses       WorkProcess[]
  youtubes            Youtube[]
  faqs                Faq[]
  contactInformations ContactInformation[]
  services            Services[]
  subServices         SubServices[]
  enums               Enum[]
  directions          Directions[]
  aboutMains          AboutMain[]
  branches            Branch[]
  photoGalleries      PhotoGallery[]
  certificates        Certificates[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model File {
  id                 Int           @id @default(autoincrement())
  fileKey            String        @unique
  originalName       String
  mimeType           String
  fileSize           Int
  publicUrl          String
  published          Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  seo                Seo?          @relation(name: "seoImg")
  categories         Categories?   @relation(name: "CategoriesImg")
  heroInfo           HeroInfo?     @relation(name: "HeroImg")
  aboutHome          AboutHome?    @relation(name: "AboutImg")
  workProcess        WorkProcess?  @relation(name: "WorkProcess")
  youtube            Youtube?      @relation(name: "youtubeFile")
  servicesImg        Services?     @relation(name: "servicesImage")
  servicesGallery    Services?     @relation(name: "servicesMainGallery", fields: [servicesId], references: [id])
  servicesId         String?
  subServicesImg     SubServices?  @relation(name: "subServicesImage")
  subServices        SubServices?  @relation(name: "subServicesMainGallery", fields: [subServicesId], references: [id])
  subServicesId      String?
  directions         Directions?   @relation(name: "directionsImage")
  features           Features?     @relation(name: "FeaturesImg")
  aboutMainImg       AboutMain?    @relation(name: "AboutMainImg")
  aboutMainGallery   AboutMain?    @relation(name: "AboutMainGallery", fields: [aboutMainId], references: [id])
  aboutMainId        String?
  photoGallerySingle PhotoGallery? @relation(name: "photoImage")
  photoGalleryImages PhotoGallery? @relation(name: "photoGallery", fields: [photoGalleryId], references: [id])
  photoGalleryId     String?
  certificates       Certificates? @relation(name: "cretificatesImage")
  certificatesImages Certificates? @relation(name: "certificatesGallery", fields: [certificatesId], references: [id])
  certificatesId     String?

  @@index([createdAt, mimeType])
}

model Seo {
  id                      String                    @id @default(cuid())
  metaDescription         String?
  metaKeywords            String?
  metaTitle               String?
  locale                  Locales                   @default(en)
  imageId                 Int?                      @unique
  imageUrl                File?                     @relation("seoImg", fields: [imageId], references: [id], onDelete: SetNull)
  categoriesTranslations  CategoriesTranslations[]
  servicesTranslations    ServicesTranslations[]
  subServicesTranslations SubServicesTranslations[]
  directionsTranslations  DirectionsTranslations[]

  @@index([locale])
  @@index([imageId])
}

model Social {
  id         String   @id @default(cuid())
  socialName String?  @unique
  socialLink String?  @unique
  iconName   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt])
}

enum Locales {
  en @map("en") // İngiliscə
  ka @map("ka") // Gürcücə
}

// categories
model Categories {
  id           String                   @id @default(cuid())
  slug         String
  isDeleted    Boolean                  @default(false)
  imageId      Int?                     @unique
  imageUrl     File?                    @relation("CategoriesImg", fields: [imageId], references: [id], onDelete: SetNull)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  translations CategoriesTranslations[]
  user         User?                    @relation(fields: [userId], references: [id])
  userId       String?

  @@index([isDeleted])
  @@index([slug, isDeleted])
  @@index([userId, isDeleted])
  @@index([createdAt])
}

model CategoriesTranslations {
  id          String      @id @default(cuid())
  title       String
  description String?
  locale      Locales     @default(en)
  document    Categories? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId  String?
  seo         Seo?        @relation(fields: [seoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  seoId       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([documentId, locale])
  @@index([locale])
  @@index([documentId])
  @@index([seoId])
  @@index([title])
}

// section
model SectionContent {
  id           String                       @id @default(cuid())
  key          String?                      @unique
  translations SectionContentTranslations[]
  user         User?                        @relation(fields: [userId], references: [id])
  userId       String?
  isDeleted    Boolean                      @default(false)
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt

  @@index([isDeleted])
  @@index([createdAt])
  @@index([key])
  @@index([userId])
  @@index([isDeleted, key])
}

model SectionContentTranslations {
  id            String          @id @default(cuid())
  title         String
  slug          String?
  subTitle      String?
  highlightWord String?
  locale        Locales         @default(en)
  document      SectionContent? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  description   String?

  @@unique([documentId, locale])
  @@index([title])
  @@index([locale])
  @@index([documentId])
  @@index([slug])
}

// hero
enum StaticKey {
  main
}

// hero
model HeroInfo {
  id           String                 @id @default(cuid())
  imageId      Int?                   @unique
  imageUrl     File?                  @relation("HeroImg", fields: [imageId], references: [id], onDelete: SetNull)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  translations HeroInfoTranslations[]
  user         User?                  @relation(fields: [userId], references: [id])
  userId       String?
  key          StaticKey              @unique @default(main)

  @@index([createdAt])
  @@index([userId])
}

model HeroInfoTranslations {
  id          String    @id @default(cuid())
  title       String
  slug        String?
  description String?
  subTitle    String?
  locale      Locales   @default(en)
  document    HeroInfo? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([documentId, locale])
  @@index([locale])
  @@index([documentId])
  @@index([slug])
  @@index([title])
}

// about
model AboutHome {
  id           String                  @id @default(cuid())
  imageId      Int?                    @unique
  imageUrl     File?                   @relation("AboutImg", fields: [imageId], references: [id], onDelete: SetNull)
  translations AboutHomeTranslations[]
  user         User?                   @relation(fields: [userId], references: [id])
  userId       String?
  key          StaticKey               @unique @default(main)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([createdAt])
  @@index([userId])
}

model AboutHomeTranslations {
  id          String     @id @default(cuid())
  title       String
  subTitle    String?
  description String?
  features    Json?
  locale      Locales    @default(en)
  document    AboutHome? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([documentId, locale])
  @@index([locale])
  @@index([documentId])
  @@index([title])
}

model Features {
  id           String                 @id @default(cuid())
  imageId      Int?                   @unique
  imageUrl     File?                  @relation("FeaturesImg", fields: [imageId], references: [id], onDelete: SetNull)
  translations FeaturesTranslations[]
  user         User?                  @relation(fields: [userId], references: [id])
  userId       String?
  key          StaticKey              @unique @default(main)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([createdAt])
  @@index([userId])
}

model FeaturesTranslations {
  id          String    @id @default(cuid())
  title       String
  subTitle    String?
  description Json?
  locale      Locales   @default(en)
  document    Features? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([documentId, locale])
  @@index([locale])
  @@index([documentId])
  @@index([title])
}

model WorkProcess {
  id           String                    @id @default(cuid())
  translations WorkProcessTranslations[]
  user         User?                     @relation(fields: [userId], references: [id])
  userId       String?
  key          StaticKey                 @unique @default(main)
  imageId      Int?                      @unique
  imageUrl     File?                     @relation("WorkProcess", fields: [imageId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([userId])
}

model WorkProcessTranslations {
  id          String       @id @default(cuid())
  title       String
  subTitle    String?
  description Json?
  locale      Locales      @default(en)
  document    WorkProcess? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([documentId, locale])
  @@index([locale])
  @@index([documentId])
  @@index([title])
}

model Youtube {
  id           String                @id @default(cuid())
  isDeleted    Boolean               @default(false)
  url          String
  imageId      Int?                  @unique
  imageUrl     File?                 @relation("youtubeFile", fields: [imageId], references: [id], onDelete: SetNull)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  translations YoutubeTranslations[]
  user         User?                 @relation(fields: [userId], references: [id])
  userId       String?
  orderNumber  Int?                  @default(1)

  @@index([isDeleted])
  @@index([createdAt])
  @@index([userId])
  @@index([isDeleted, createdAt])
}

model YoutubeTranslations {
  id         String   @id @default(cuid())
  title      String
  slug       String
  locale     Locales  @default(en)
  document   Youtube? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([documentId, locale])
  @@index([locale])
  @@index([documentId])
  @@index([slug])
  @@index([title])
}

model Faq {
  id           String            @id @default(cuid())
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @default(now())
  translations FaqTranslations[]
  user         User?             @relation(fields: [userId], references: [id])
  userId       String?
  orderNumber  Int?              @default(1)
  isDeleted    Boolean           @default(false)

  @@index([isDeleted])
  @@index([createdAt])
  @@index([userId])
  @@index([orderNumber])
  @@index([isDeleted, createdAt])
}

model FaqTranslations {
  id          String   @id @default(cuid())
  title       String
  slug        String?
  locale      Locales  @default(en)
  document    Faq?     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  description String?

  @@unique([documentId, locale])
  @@index([title])
  @@index([locale])
  @@index([documentId])
  @@index([slug])
}

model ContactInformation {
  id           String                          @id @default(cuid())
  createdAt    DateTime                        @default(now())
  updatedAt    DateTime                        @updatedAt
  phone        String?
  latitude     String?
  longitude    String?
  adressLink   String?
  whatsapp     String?
  email        String?
  translations ContactInformationTranslation[]
  user         User?                           @relation(fields: [userId], references: [id])
  userId       String?
  key          StaticKey                       @unique @default(main)

  @@index([createdAt])
  @@index([phone])
  @@index([email])
  @@index([userId])
}

model ContactInformationTranslation {
  id         String             @id @default(cuid())
  adress     String?
  documentId String
  locale     Locales            @default(en)
  document   ContactInformation @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([documentId, locale])
  @@index([locale])
}

model Services {
  id           String                 @id @default(cuid())
  isDeleted    Boolean                @default(false)
  imageId      Int?                   @unique
  imageUrl     File?                  @relation("servicesImage", fields: [imageId], references: [id], onDelete: SetNull)
  orderNumber  Int                    @default(1)
  translations ServicesTranslations[]
  user         User?                  @relation(fields: [userId], references: [id])
  userId       String?
  gallery      File[]                 @relation("servicesMainGallery")
  subServices  SubServices[]
  aboutMains   AboutMain[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([isDeleted, orderNumber])
  @@index([userId, isDeleted])
}

model ServicesTranslations {
  id          String    @id @default(cuid())
  title       String
  slug        String?
  description Json?
  locale      Locales   @default(en)
  document    Services? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId  String?
  seo         Seo?      @relation(fields: [seoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  seoId       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([documentId, locale])
  @@index([locale])
  @@index([documentId])
  @@index([slug])
  @@index([title])
  @@index([seoId])
}

model SubServices {
  id           String                    @id @default(cuid())
  isDeleted    Boolean                   @default(false)
  imageId      Int?                      @unique
  imageUrl     File?                     @relation("subServicesImage", fields: [imageId], references: [id], onDelete: SetNull)
  orderNumber  Int                       @default(1)
  translations SubServicesTranslations[]
  user         User?                     @relation(fields: [userId], references: [id])
  userId       String?
  gallery      File[]                    @relation("subServicesMainGallery")
  iconsUrl     String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  services     Services?                 @relation(fields: [servicesId], references: [id])
  servicesId   String?

  @@index([isDeleted, orderNumber])
  @@index([userId, isDeleted])
}

model SubServicesTranslations {
  id          String       @id @default(cuid())
  title       String
  slug        String?
  description Json?
  locale      Locales      @default(en)
  document    SubServices? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId  String?
  seo         Seo?         @relation(fields: [seoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  seoId       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([documentId, locale])
  @@index([locale])
  @@index([documentId])
  @@index([slug])
  @@index([title])
  @@index([seoId])
}

model Enum {
  id           String             @id @default(cuid())
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @default(now())
  translations EnumTranslations[]
  user         User?              @relation(fields: [userId], references: [id])
  userId       String?
  orderNumber  Int?               @default(0)
  isDeleted    Boolean            @default(false)
  key          EnumKey

  @@index([isDeleted])
  @@index([createdAt])
  @@index([userId])
  @@index([orderNumber])
}

model EnumTranslations {
  id         String   @id @default(cuid())
  title      String
  slug       String?
  locale     Locales  @default(en)
  document   Enum?    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([documentId, locale])
  @@index([title])
  @@index([locale])
  @@index([documentId])
  @@index([slug])
}

enum EnumKey {
  contact
}

model Directions {
  id           String                   @id @default(cuid())
  isDeleted    Boolean                  @default(false)
  imageId      Int?                     @unique
  imageUrl     File?                    @relation("directionsImage", fields: [imageId], references: [id], onDelete: SetNull)
  orderNumber  Int                      @default(1)
  translations DirectionsTranslations[]
  user         User?                    @relation(fields: [userId], references: [id])
  userId       String?
  route        Json
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([isDeleted, orderNumber])
  @@index([userId, isDeleted])
}

model DirectionsTranslations {
  id               String      @id @default(cuid())
  title            String
  navTitle         String
  slug             String
  shortDescription String?
  description      Json?
  locale           Locales     @default(en)
  document         Directions? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId       String?
  seo              Seo?        @relation(fields: [seoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  seoId            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([documentId, locale])
  @@index([locale])
  @@index([documentId])
  @@index([slug])
  @@index([title])
  @@index([seoId])
}

model AboutMain {
  id           String                  @id @default(cuid())
  imageId      Int?                    @unique
  imageUrl     File?                   @relation("AboutMainImg", fields: [imageId], references: [id], onDelete: SetNull)
  translations AboutMainTranslations[]
  user         User?                   @relation(fields: [userId], references: [id])
  userId       String?
  key          StaticKey               @unique @default(main)
  gallery      File[]                  @relation("AboutMainGallery")
  branches     Branch[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  service      Services?               @relation(fields: [serviceId], references: [id])
  serviceId    String?

  @@index([createdAt])
  @@index([userId])
}

model AboutMainTranslations {
  id               String     @id @default(cuid())
  title            String
  hightlight       String?
  subTitle         String?
  shortDescription String?
  description      Json?
  locale           Locales    @default(en)
  document         AboutMain? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId       String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([documentId, locale])
  @@index([locale])
  @@index([documentId])
  @@index([title])
}

enum BranchStatus {
  ACTIVE
  PLANNED
}

// branches
model Branch {
  id           String              @id @default(cuid())
  isoCode      String              @unique
  status       BranchStatus        @default(ACTIVE)
  isDeleted    Boolean             @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  translations BranchTranslation[]
  user         User?               @relation(fields: [userId], references: [id])
  userId       String?
  orderNumber  Int?                @default(1)
  offices      Office[]
  aboutMain    AboutMain?          @relation(fields: [aboutMainId], references: [id])
  aboutMainId  String?

  @@index([isoCode])
  @@index([status])
  @@index([isDeleted])
  @@index([createdAt])
  @@index([userId])
  @@index([isDeleted, status])
}

model BranchTranslation {
  id          String   @id @default(cuid())
  countryName String
  locale      Locales  @default(en)
  branch      Branch?  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([documentId, locale])
  @@index([locale])
  @@index([documentId])
  @@index([countryName])
}

enum BranchType {
  office
  warehouse
}

model Office {
  id           String              @id @default(cuid())
  isDeleted    Boolean             @default(false)
  branch       Branch?             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branchId     String?
  type         BranchType?         @default(office)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  orderNumber  Int?                @default(1)
  translations OfficeTranslation[]

  @@index([branchId])
  @@index([isDeleted])
  @@index([orderNumber])
}

model OfficeTranslation {
  id         String   @id @default(cuid())
  city       String
  address    String?
  locale     Locales
  office     Office?  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([documentId, locale])
  @@index([documentId])
  @@index([locale])
  @@index([city])
}

model PhotoGallery {
  id           String                     @id @default(cuid())
  isDeleted    Boolean                    @default(false)
  imageId      Int?                       @unique
  imageUrl     File?                      @relation("photoImage", fields: [imageId], references: [id], onDelete: SetNull)
  orderNumber  Int                        @default(1)
  translations PhotoGalleryTranslations[]
  user         User?                      @relation(fields: [userId], references: [id])
  userId       String?
  gallery      File[]                     @relation("photoGallery")
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  @@index([isDeleted, orderNumber])
  @@index([userId, isDeleted])
}

model PhotoGalleryTranslations {
  id          String        @id @default(cuid())
  title       String
  slug        String?
  description String?
  locale      Locales       @default(en)
  document    PhotoGallery? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([documentId, locale])
  @@index([locale])
  @@index([documentId])
  @@index([slug])
  @@index([title])
}

model Certificates {
  id           String                     @id @default(cuid())
  isDeleted    Boolean                    @default(false)
  imageId      Int?                       @unique
  imageUrl     File?                      @relation("cretificatesImage", fields: [imageId], references: [id], onDelete: SetNull)
  orderNumber  Int                        @default(1)
  translations CertificatesTranslations[]
  user         User?                      @relation(fields: [userId], references: [id])
  userId       String?
  gallery      File[]                     @relation("certificatesGallery")
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  @@index([isDeleted, orderNumber])
  @@index([userId, isDeleted])
}

model CertificatesTranslations {
  id          String        @id @default(cuid())
  title       String
  slug        String?
  description String?
  locale      Locales       @default(en)
  document    Certificates? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([documentId, locale])
  @@index([locale])
  @@index([documentId])
  @@index([slug])
  @@index([title])
}
